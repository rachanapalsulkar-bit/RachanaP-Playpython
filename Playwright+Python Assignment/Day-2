#Build Login class with validation method
class Login:
    def validate(self, username, password):
        if username == "root" and password == "redhat":
            print("Login Successful")
        else:
            print("Login Failed")
            
# Example
login = Login()

login.validate("root", "redhat")
login.validate("user", "1111")

#Create reusable login module
def login(username, password):
    login_instance = Login()
    login_instance.validate(username, password)
# Example
login("root", "redhat")
login("user", "1111")

